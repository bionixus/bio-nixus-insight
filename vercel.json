{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/indexnow-key.ts": {
      "includeFiles": "{dist/**,seo-noise-query.mjs,lib/og-card-svg.mjs}"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/index.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/healthcare-market-research/united-kingdom",
      "destination": "/healthcare-market-research/uk",
      "statusCode": 301
    },
    {
      "source": "/conf/",
      "destination": "/conf",
      "statusCode": 301
    },
    {
      "source": "/conf/strategic-portfolio.html",
      "destination": "/conf",
      "statusCode": 301
    },
    {
      "source": "/ar/conf/",
      "destination": "/ar/conf",
      "statusCode": 301
    },
    {
      "source": "/conf/strategic-portfolio-ar.html",
      "destination": "/ar/conf",
      "statusCode": 301
    },
    {
      "source": "/bionixus-vs-iqvia-mena/",
      "destination": "/bionixus-vs-iqvia-mena",
      "statusCode": 301
    },
    {
      "source": "/kol-mapping-saudi-arabia-oncology/",
      "destination": "/kol-mapping-saudi-arabia-oncology",
      "statusCode": 301
    },
    {
      "source": "/physician-survey-saudi-arabia/",
      "destination": "/physician-survey-saudi-arabia",
      "statusCode": 301
    },
    {
      "source": "/sfda-market-access-strategy-saudi-arabia/",
      "destination": "/sfda-market-access-strategy-saudi-arabia",
      "statusCode": 301
    },
    {
      "source": "/biosimilar-market-entry-saudi-arabia/",
      "destination": "/biosimilar-market-entry-saudi-arabia",
      "statusCode": 301
    },
    {
      "source": "/iqvia-alternative/",
      "destination": "/iqvia-alternative",
      "statusCode": 301
    },
    {
      "source": "/pharmaceutical-market-research-dubai/",
      "destination": "/pharmaceutical-market-research-dubai",
      "statusCode": 301
    },
    {
      "source": "/kantar-health-alternative-gcc/",
      "destination": "/kantar-health-alternative-gcc",
      "statusCode": 301
    },
    {
      "source": "/gfk-alternative-egypt/",
      "destination": "/gfk-alternative-egypt",
      "statusCode": 301
    },
    {
      "source": "/blog/saudi-healthcare-market-research-firms-ar",
      "destination": "/ar/blog/saudi-healthcare-market-research-firms-ar",
      "statusCode": 301
    },
    {
      "source": "/blog/gcc-pharmaceuticals-market-arabic-2026",
      "destination": "/ar/blog/gcc-pharmaceuticals-market-arabic-2026",
      "statusCode": 301
    },
    {
      "source": "/blog/middle-east-healthcare-market-statistics-2025",
      "destination": "/blog/middle-east-healthcare-market-statistics-2026",
      "statusCode": 301
    },
    {
      "source": "/assets/index-:hash.js",
      "destination": "/assets/index.js",
      "statusCode": 301
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.bionixus.com"
        },
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://www.bionixus.com/:path",
      "statusCode": 301
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "bionixus.com"
        },
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://www.bionixus.com/:path",
      "statusCode": 301
    },
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "bionixus.com"
        }
      ],
      "destination": "https://www.bionixus.com/:path",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/api/og-card",
      "destination": "/api/indexnow-key"
    },
    {
      "source": "/conf",
      "destination": "/conf/strategic-portfolio.html"
    },
    {
      "source": "/ar/conf",
      "destination": "/conf/strategic-portfolio-ar.html"
    },
    {
      "source": "/bionixus-vs-iqvia-mena",
      "destination": "/conf/bionixus-vs-iqvia-mena.html"
    },
    {
      "source": "/kol-mapping-saudi-arabia-oncology",
      "destination": "/conf/kol-mapping-saudi-arabia-oncology.html"
    },
    {
      "source": "/physician-survey-saudi-arabia",
      "destination": "/conf/physician-survey-saudi-arabia.html"
    },
    {
      "source": "/sfda-market-access-strategy-saudi-arabia",
      "destination": "/conf/sfda-market-access-strategy-saudi-arabia.html"
    },
    {
      "source": "/biosimilar-market-entry-saudi-arabia",
      "destination": "/conf/biosimilar-market-entry-saudi-arabia.html"
    },
    {
      "source": "/iqvia-alternative",
      "destination": "/conf/iqvia-alternative.html"
    },
    {
      "source": "/pharmaceutical-market-research-dubai",
      "destination": "/conf/pharmaceutical-market-research-dubai.html"
    },
    {
      "source": "/kantar-health-alternative-gcc",
      "destination": "/conf/kantar-health-alternative-gcc.html"
    },
    {
      "source": "/gfk-alternative-egypt",
      "destination": "/conf/gfk-alternative-egypt.html"
    },
    {
      "source": "/blog/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|facebot|Twitterbot|twitterbot|LinkedInBot|linkedinbot|WhatsApp|whatsapp|Slackbot|slackbot|TelegramBot|telegrambot|Discordbot|discordbot|Googlebot|googlebot|bingbot|Bingbot|Pinterestbot|pinterestbot|redditbot|Redditbot|AhrefsBot|ahrefsbot|AhrefsSiteAudit|ChatGPT-User|OAI-SearchBot|GPTBot|ClaudeBot|PerplexityBot|anthropic-ai|Applebot|cohere-ai|Bytespider).*"
        }
      ],
      "destination": "/api/blog/:slug"
    },
    {
      "source": "/case-studies/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|facebot|Twitterbot|twitterbot|LinkedInBot|linkedinbot|WhatsApp|whatsapp|Slackbot|slackbot|TelegramBot|telegrambot|Discordbot|discordbot|Googlebot|googlebot|bingbot|Bingbot|Pinterestbot|pinterestbot|redditbot|Redditbot|AhrefsBot|ahrefsbot|AhrefsSiteAudit|ChatGPT-User|OAI-SearchBot|GPTBot|ClaudeBot|PerplexityBot|anthropic-ai|Applebot|cohere-ai|Bytespider).*"
        }
      ],
      "destination": "/api/case-studies/:slug"
    },
    {
      "source": "/unsubscribe",
      "destination": "/api/unsubscribe"
    },
    {
      "source": "/",
      "destination": "/api/indexnow-key?__ssr=1&url=/"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/api/indexnow-key?__ssr=1&url=/:path"
    }
  ]
}